    private void displayScaledImage(File file) {
        ImageIcon icon = new ImageIcon(file.getAbsolutePath());
        Image img = icon.getImage().getScaledInstance(300, 250, Image.SCALE_SMOOTH);
        imagePreviewLabel.setIcon(new ImageIcon(img));
        imagePreviewLabel.setText("");
        imagePreviewLabel.revalidate();
        imagePreviewLabel.repaint();
    }

    private boolean validateForm() {
        if (nameField.getText().trim().isEmpty()) {
            JOptionPane.showMessageDialog(this, "Το όνομα είναι υποχρεωτικό!", "Missing Data", JOptionPane.WARNING_MESSAGE);
            return false;
        }
        if (brandField.getText().trim().isEmpty()) {
            JOptionPane.showMessageDialog(this, "Η μάρκα είναι υποχρεωτική!", "Missing Data", JOptionPane.WARNING_MESSAGE);
            return false;
        }
        return true;
    }

    private void saveFullRecord() {
        if (!validateForm()) return;
        try {
            Path imageDir = Paths.get("saved_images");
            if (!Files.exists(imageDir)) Files.createDirectories(imageDir);

            String timestamp = LocalDateTime.now().format(DateTimeFormatter.ofPattern("yyyyMMdd_HHmmss"));
            String imagePath = "None";
            if (selectedImageFile != null) {
                String fileName = timestamp + "_" + nameField.getText().replaceAll("\\s+", "") + ".jpg";
                Path targetPath = imageDir.resolve(fileName);
                Files.copy(selectedImageFile.toPath(), targetPath, StandardCopyOption.REPLACE_EXISTING);
                imagePath = targetPath.toString();
            }

            StringBuilder selectedServices = new StringBuilder();
            DefaultTableModel model = (DefaultTableModel) serviceTable.getModel();
            for (int i = 0; i < model.getRowCount(); i++) {
                if ((Boolean) model.getValueAt(i, 1)) {
                    if (selectedServices.length() > 0) selectedServices.append(", ");
                    selectedServices.append(model.getValueAt(i, 0));
                }
            }
            String servicesData = selectedServices.length() == 0 ? "None" : selectedServices.toString();

            try (PrintWriter out = new PrintWriter(new FileWriter("repairs_log.csv", true))) {
                out.printf("%s|%s|%s|%s|%s|%s\n", timestamp, nameField.getText(), brandField.getText(), modelField.getText(), servicesData, imagePath);
            }
            JOptionPane.showMessageDialog(this, "Record Saved!");
        } catch (Exception ex) {
            ex.printStackTrace();
        }
    }

    private void generatePDF() {
        if (!validateForm()) return;
        
        String timestamp = LocalDateTime.now().format(DateTimeFormatter.ofPattern("yyyyMMdd_HHmmss"));
        String fileName = "Receipt_" + nameField.getText().replaceAll("\\s+", "") + "_" + timestamp + ".pdf";

        try (PDDocument document = new PDDocument()) {
            PDPage page = new PDPage();
            document.addPage(page);

            // --- LOAD BUNDLED GREEK FONTS ---
            // These look for arial.ttf in the SAME FOLDER as your .java/.jar file
            File regularFile = new File("arial.ttf");
            File boldFile = new File("arialbd.ttf"); // Optional: copy arialbd.ttf too

            org.apache.pdfbox.pdmodel.font.PDFont font;
            org.apache.pdfbox.pdmodel.font.PDFont fontBold;

            if (regularFile.exists()) {
                font = org.apache.pdfbox.pdmodel.font.PDType0Font.load(document, regularFile);
                // Use bold if exists, otherwise use regular
                fontBold = boldFile.exists() ? org.apache.pdfbox.pdmodel.font.PDType0Font.load(document, boldFile) : font;
            } else {
                JOptionPane.showMessageDialog(this, 
                    "Κρίσιμο Σφάλμα: Το αρχείο arial.ttf λείπει από τον φάκελο της εφαρμογής!\n" +
                    "Please place arial.ttf in the project folder.", "Font Error", JOptionPane.ERROR_MESSAGE);
                return;
            }

            try (PDPageContentStream contentStream = new PDPageContentStream(document, page)) {
                
                // --- HEADER ---
                contentStream.beginText();
                contentStream.setFont(fontBold, 18);
                contentStream.newLineAtOffset(50, 750);
                contentStream.showText("ΔΕΛΤΙΟ ΠΑΡΑΛΑΒΗΣ ΕΠΙΣΚΕΥΗΣ");
                contentStream.endText();

                contentStream.beginText();
                contentStream.setFont(font, 12);
                contentStream.setLeading(18f);
                contentStream.newLineAtOffset(50, 710);

                // --- CUSTOMER DATA ---
                contentStream.showText("Πελάτης: " + nameField.getText().trim());
                contentStream.newLine();
                contentStream.showText("Διεύθυνση: " + addressField.getText().trim() + ", " + cityField.getText().trim());
                contentStream.newLine();
                contentStream.showText("Τηλέφωνο: " + telField.getText().trim());
                contentStream.newLine();
                contentStream.newLine();

                // --- WATCH DATA ---
                contentStream.setFont(fontBold, 12);
                contentStream.showText("ΣΤΟΙΧΕΙΑ ΩΡΟΛΟΓΙΟΥ:");
                contentStream.setFont(font, 12);
                contentStream.newLine();
                contentStream.showText("Μάρκα: " + brandField.getText().trim() + " | Model: " + modelField.getText().trim());
                contentStream.newLine();
                contentStream.showText("REF: " + refField.getText().trim());
                contentStream.newLine();
                contentStream.newLine();

                // --- SERVICES ---
                contentStream.setFont(fontBold, 12);
                contentStream.showText("ΕΡΓΑΣΙΕΣ:");
                contentStream.setFont(font, 12);
                contentStream.newLine();

                DefaultTableModel model = (DefaultTableModel) serviceTable.getModel();
                for (int i = 0; i < model.getRowCount(); i++) {
                    if ((Boolean) model.getValueAt(i, 1)) {
                        String service = model.getValueAt(i, 0).toString();
                        String notes = model.getValueAt(i, 2).toString();
                        contentStream.showText("- " + service + (notes.isEmpty() ? "" : " (" + notes + ")"));
                        contentStream.newLine();
                    }
                }
                contentStream.endText();

                // --- IMAGE ---
                if (selectedImageFile != null && selectedImageFile.exists()) {
                    PDImageXObject pdImage = PDImageXObject.createFromFile(selectedImageFile.getAbsolutePath(), document);
                    // Adjust image position based on list length (approximate)
                    float imageY = 400 - (model.getRowCount() * 5); 
                    contentStream.drawImage(pdImage, 50, 200, 300, 225);
                }
            }

            document.save(fileName);
            JOptionPane.showMessageDialog(this, "Το PDF δημιουργήθηκε: " + fileName);
            Desktop.getDesktop().open(new File(fileName));

        } catch (Exception e) {
            JOptionPane.showMessageDialog(this, "Σφάλμα PDF: " + e.getMessage());
            e.printStackTrace();
        }
    }

    private void showLoadDialog() {
        DefaultListModel<String> listModel = new DefaultListModel<>();
        List<String[]> allRecords = new ArrayList<>();
        try (BufferedReader br = new BufferedReader(new FileReader("repairs_log.csv"))) {
            String line;
            while ((line = br.readLine()) != null) {
                String[] parts = line.split("\\|");
                allRecords.add(parts);
                listModel.addElement(parts[1] + " (" + parts[0] + ")");
            }
        } catch (IOException e) {
            JOptionPane.showMessageDialog(this, "No records found.");
            return;
        }
        JList<String> list = new JList<>(listModel);
        if (JOptionPane.showConfirmDialog(this, new JScrollPane(list), "Select Record", JOptionPane.OK_CANCEL_OPTION) == JOptionPane.OK_OPTION && list.getSelectedIndex() != -1) {
            populateForm(allRecords.get(list.getSelectedIndex()));
        }
    }

    private void populateForm(String[] data) {
        nameField.setText(data[1]);
        brandField.setText(data[2]);
        modelField.setText(data[3]);
        String savedServices = data[4];
        DefaultTableModel model = (DefaultTableModel) serviceTable.getModel();
        for (int i = 0; i < model.getRowCount(); i++) {
            model.setValueAt(savedServices.contains(model.getValueAt(i, 0).toString()), i, 1);
        }
        if (!data[5].equals("None")) {
            selectedImageFile = new File(data[5]);
            if (selectedImageFile.exists()) displayScaledImage(selectedImageFile);
        }
    }
    
