    private JPanel createHeaderPanel() {
        JPanel panel = new JPanel(new GridBagLayout());
        panel.setBorder(BorderFactory.createTitledBorder("Στοιχεία Πελάτη & Ωρολογίου"));
        GridBagConstraints gbc = new GridBagConstraints();
